# ============================================================
# Pakistan Disaster Pipeline — API Configuration Example
# ============================================================
# Rename this file to `config.py` and fill in your Reddit credentials.
# All other sources (USGS, GDELT, GDACS, ReliefWeb) are FREE
# and require NO API key.
# ============================================================

# ----------------------------------------------------------
# REDDIT API (get from: https://www.reddit.com/prefs/apps)
# ----------------------------------------------------------
REDDIT_CLIENT_ID     = "YOUR_CLIENT_ID_HERE"
REDDIT_CLIENT_SECRET = "YOUR_CLIENT_SECRET_HERE"
REDDIT_USER_AGENT    = "disaster_pipeline:v1.0 (by /u/YOUR_USERNAME)"

# ----------------------------------------------------------
# ReliefWeb — No key required (app name optional)
# Docs: https://apidoc.reliefweb.int/
# ----------------------------------------------------------
RELIEFWEB_APP_NAME = "smart-disaster-pipeline"
